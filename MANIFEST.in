# Belt-and-braces inclusion of the dashboard's static JSON asset.
#
# pyproject.toml [tool.setuptools.package-data] already declares this,
# but a separate MANIFEST.in covers older setuptools and the case where
# pip's wheel cache reuses a wheel built before the package-data line
# existed. Streamlit Cloud's pip install . occasionally hits the latter.
recursive-include src/sat_tracker/dashboard/static *.json
recursive-include src/sat_tracker/dashboard/static/bundled_tles *.txt
